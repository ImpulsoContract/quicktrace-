generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("quicktrace_POSTGRES_PRISMA_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("CLIENT") // ADMIN, CLIENT
  
  emailVerified            Boolean   @default(false)
  verificationToken        String?
  verificationTokenExpires DateTime?
  resetPasswordToken       String?
  resetPasswordExpires     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientProfile ClientProfile?
}

model ClientProfile {
  id                     Int      @id @default(autoincrement())
  userId                 Int      @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  razonSocial            String
  nif                    String
  phone                  String?
  urlClientify           String?
  personName             String?
  
  // Invoice/Profile Info
  address                String?
  postalCode             String?
  city                   String?
  province               String?
  country                String? @default("España")
  
  // New Plan System
  planId                String?
  plan                  PricingPlan? @relation(fields: [planId], references: [id])
  
  // Campos de Stripe
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd String?
  
  // Old fields (to be deprecated after migration)
  accountType           String   @default("DEMO") 
  recetasContratadas     Int      @default(3)
  
  canManageRecipes      Boolean  @default(true)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  recipes               Recipe[]
  cleaningZones         CleaningZone[]
  cleaningLogs          CleaningLog[]
  chambers              Chamber[]
  temperatureRecords    TemperatureRecord[]
  goodsReceipts         GoodsReceipt[]
}

model PricingPlan {
  id                String          @id @default(cuid())
  name              String          @unique
  priceMonthly      Float           @default(0)
  priceYearly       Float           @default(0)
  stripePriceIdMonthly String?
  stripePriceIdYearly  String?
  
  // Legacy field
  stripePriceId     String?         // Will be migrated to stripePriceIdYearly
  
  recipesLimit      Int?            // null = ilimitadas
  elaborationsLimit Int?
  
  hasCleaning       Boolean         @default(false)
  cleaningLimit     Int?
  
  hasGoods          Boolean         @default(false)
  goodsLimit        Int?
  
  hasTemperatures   Boolean         @default(false)
  temperaturesLimit Int?
  
  clients           ClientProfile[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model Recipe {
  id              Int          @id @default(autoincrement())
  name            String
  clientProfileId Int
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  
  ingredients     Ingredient[]
  elaborations    Elaboration[]
  
  lotesMandatory      Boolean  @default(false)
  quantitiesMandatory   Boolean  @default(false)
  expiryDays            Int?     @default(0)
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Ingredient {
  id        Int      @id @default(autoincrement())
  recipeId  Int
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  
  name      String
  amount    String
  unit      String
  
  loteMandatory     Boolean  @default(false)
  quantityMandatory Boolean  @default(false)
  
  createdAt DateTime @default(now())
}

model Elaboration {
  id        Int      @id @default(autoincrement())
  name      String
  date      DateTime @default(now())
  
  recipeId  Int
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  
  personName      String?
  expirationDate  DateTime?
  
  ingredients ElaborationIngredient[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ElaborationIngredient {
  id            Int         @id @default(autoincrement())
  elaborationId Int
  elaboration   Elaboration @relation(fields: [elaborationId], references: [id], onDelete: Cascade)
  
  name          String
  lote          String?
  realAmount    String
  unit          String
  
  createdAt     DateTime    @default(now())
}

model CleaningZone {
  id              Int           @id @default(autoincrement())
  name            String
  clientProfileId Int
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  
  logs            CleaningLogZone[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model CleaningLog {
  id              Int           @id @default(autoincrement())
  personName      String
  date            DateTime      @default(now())
  clientProfileId Int
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  
  zones           CleaningLogZone[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model CleaningLogZone {
  cleaningLogId  Int
  cleaningLog    CleaningLog  @relation(fields: [cleaningLogId], references: [id], onDelete: Cascade)
  cleaningZoneId Int
  cleaningZone   CleaningZone @relation(fields: [cleaningZoneId], references: [id], onDelete: Cascade)

  @@id([cleaningLogId, cleaningZoneId])
}

model Chamber {
  id              Int           @id @default(autoincrement())
  name            String
  clientProfileId Int
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  
  values          TemperatureValue[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model TemperatureRecord {
  id              Int           @id @default(autoincrement())
  date            DateTime      @default(now())
  clientProfileId Int
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  
  values          TemperatureValue[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model TemperatureValue {
  id                  Int               @id @default(autoincrement())
  value               Float
  chamberId           Int
  chamber             Chamber           @relation(fields: [chamberId], references: [id], onDelete: Cascade)
  temperatureRecordId Int
  record              TemperatureRecord @relation(fields: [temperatureRecordId], references: [id], onDelete: Cascade)
}

model GoodsReceipt {
  id                Int           @id @default(autoincrement())
  providerName      String?
  productName       String
  lote              String?
  invoiceNumber     String?
  quantity          String?
  date              DateTime      @default(now())
  deliveryNoteImage String?       // Base64 or URL
  
  clientProfileId   Int
  clientProfile     ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}
